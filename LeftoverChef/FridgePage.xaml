<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeftoverChef.FridgePage"
             BackgroundImageSource="fridge_bg.jpg"
             Shell.NavBarIsVisible="False" NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="*, Auto">

        <Grid Grid.Row="0">

            <Grid x:Name="CategoryView" Opacity="1" IsVisible="True" Padding="20" RowDefinitions="Auto, *, *">
                <Label Grid.Row="0" Text="My Fridge" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,20"/>

                <Border Grid.Row="1" StrokeShape="RoundRectangle 15" BackgroundColor="#E3F2FD" Margin="0,10" Padding="20">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="Fridge"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                        <Label Text="🥬" FontSize="60" HorizontalOptions="Center"/>
                        <Label Text="Fridge (Chiller)" FontSize="24" FontAttributes="Bold" TextColor="#1565C0"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="2" StrokeShape="RoundRectangle 15" BackgroundColor="#E0F7FA" Margin="0,10" Padding="20">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="Freezer"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                        <Label Text="❄️" FontSize="60" HorizontalOptions="Center"/>
                        <Label Text="Freezer" FontSize="24" FontAttributes="Bold" TextColor="#00838F"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Grid x:Name="IngredientListGrid" Opacity="0" IsVisible="False" RowDefinitions="Auto, Auto, *">

                <Grid Grid.Row="0" Padding="15" BackgroundColor="#EEEEEE">
                    <Label x:Name="ListTitleLabel" FontAttributes="Bold" FontSize="18" VerticalOptions="Center" HorizontalOptions="Start"/>
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="*, Auto" Padding="15,10" BackgroundColor="#FFFFFF">
                    <Border Grid.Column="0" StrokeShape="RoundRectangle 10" BackgroundColor="#F5F5F5" StrokeThickness="0" Margin="0,0,10,0">
                        <Entry x:Name="NewIngredientEntry" Placeholder="Add new item..." FontSize="16" Margin="10,0"/>
                    </Border>
                    <Button Grid.Column="1" Text="➕" Clicked="OnAddIngredientClicked" BackgroundColor="#28A745" TextColor="White" FontAttributes="Bold" WidthRequest="50" CornerRadius="10"/>
                </Grid>

                <ScrollView Grid.Row="2" Padding="15">
                    <VerticalStackLayout x:Name="IngredientListContainer" Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeShape="RoundRectangle 10" BackgroundColor="#F8F9FA" Padding="15,10">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Label Grid.Column="0" Text="{Binding Name}" FontAttributes="Bold" FontSize="16" TextColor="#333333" VerticalOptions="Center"/>
                                        <Button Grid.Column="1" Text="❌" Clicked="OnDeleteIngredientClicked" CommandParameter="{Binding .}" BackgroundColor="Transparent" TextColor="Red" Padding="0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>

        </Grid>

        <Button Grid.Row="1" x:Name="DynamicBottomButton" Text="🏠 Back to Home" Clicked="OnDynamicBottomClicked" BackgroundColor="#2A009F" TextColor="White" FontAttributes="Bold" FontSize="18" HeightRequest="60" CornerRadius="0" Margin="0" VerticalOptions="End"/>
    </Grid>
</ContentPage>