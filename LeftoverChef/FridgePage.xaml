<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeftoverChef.FridgePage"
             BackgroundImageSource="fridge_bg.jpg"
             Shell.NavBarIsVisible="False" NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="*, Auto">
        <Grid Grid.Row="0">
            <ScrollView x:Name="CategoryView" Opacity="1" IsVisible="True">
                <VerticalStackLayout Padding="20" Spacing="10">
                    <Label Text="My Fridge" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,20" TextColor="#2C3E50"/>

                    <Border Stroke="#80FFFFFF" StrokeThickness="1.5" StrokeShape="RoundRectangle 15" Margin="0,10" Padding="20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#D9FFFFFF" Offset="0.0" />
                                <GradientStop Color="#66E3F2FD" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="Fridge"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                            <Label Text="🥬" FontSize="60" HorizontalOptions="Center"/>
                            <Label Text="Fridge (Chiller)" FontSize="24" FontAttributes="Bold" TextColor="#1565C0"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Stroke="#80FFFFFF" StrokeThickness="1.5" StrokeShape="RoundRectangle 15" Margin="0,10" Padding="20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#D9FFFFFF" Offset="0.0" />
                                <GradientStop Color="#66E0F7FA" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.1" Offset="0,5" Radius="10" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="Freezer"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                            <Label Text="❄️" FontSize="60" HorizontalOptions="Center"/>
                            <Label Text="Freezer" FontSize="24" FontAttributes="Bold" TextColor="#00838F"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Stroke="#80FFFFFF" StrokeThickness="1.5" StrokeShape="RoundRectangle 15" Margin="0,10" Padding="20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#D9FFFFFF" Offset="0.0" />
                                <GradientStop Color="#66F3E5F5" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSmartMatchTapped"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                            <Label Text="🪄" FontSize="60" HorizontalOptions="Center"/>
                            <Label Text="Smart Match" FontSize="24" FontAttributes="Bold" TextColor="#7B1FA2"/>
                            <Label Text="What can I cook today?" FontSize="12" TextColor="#555555"/>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>

            <Grid x:Name="IngredientListGrid" Opacity="0" IsVisible="False" RowDefinitions="Auto, Auto, *">
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto, Auto" Padding="15" BackgroundColor="#80FFFFFF">
                    <Label Grid.Column="0" x:Name="ListTitleLabel" FontAttributes="Bold" FontSize="18" VerticalOptions="Center" TextColor="#333333"/>
                    <Button Grid.Column="1" Text="🗑️ Clear" Clicked="OnDeleteAllClicked" FontSize="11" Margin="5,0"/>
                    <Button Grid.Column="2" Text="↩️ Undo" Clicked="OnUndoClicked" FontSize="11"/>
                </Grid>
                <Grid Grid.Row="1" ColumnDefinitions="*, Auto" Padding="15,10" BackgroundColor="#80FFFFFF">
                    <Border Grid.Column="0" StrokeShape="RoundRectangle 10" BackgroundColor="#E6FFFFFF" StrokeThickness="0" Margin="0,0,10,0">
                        <Entry x:Name="NewIngredientEntry" Placeholder="Add item..." FontSize="16" Margin="10,0" TextColor="Black"/>
                    </Border>
                    <Button Grid.Column="1" Text="➕" Clicked="OnAddIngredientClicked" BackgroundColor="#28A745" TextColor="White" WidthRequest="50"/>
                </Grid>
                <ScrollView Grid.Row="2" Padding="15">
                    <VerticalStackLayout x:Name="IngredientListContainer" Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="#99FFFFFF" StrokeThickness="1" Padding="15,10" StrokeShape="RoundRectangle 10" BackgroundColor="#CCFFFFFF">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" TextColor="#333333" VerticalOptions="Center"/>
                                        <Button Grid.Column="1" Text="❌" Clicked="OnDeleteIngredientClicked" CommandParameter="{Binding .}" BackgroundColor="Transparent" TextColor="Red"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Grid>
        <Button Grid.Row="1" x:Name="DynamicBottomButton" Text="🏠 Back to Home" Clicked="OnDynamicBottomClicked" BackgroundColor="#2A009F" HeightRequest="60" CornerRadius="0"/>
    </Grid>
</ContentPage>