<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeftoverChef.SearchPage"
             Title="Search Recipes"
             BackgroundImageSource="bg.png"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="*, Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="15">
                <Border BackgroundColor="#E6FFFFFF" Padding="15" Stroke="Transparent">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="What's in your fridge?" FontSize="18" FontAttributes="Bold" TextColor="Black"/>
                        <Entry x:Name="IngredientInput" Placeholder="e.g. Egg, Pork" BackgroundColor="White"/>
                        <Button Text="Find Match" BackgroundColor="#FFA500" FontAttributes="Bold" TextColor="White" Clicked="OnFindMatchingRecipesClicked"/>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout x:Name="ResultsList" Spacing="0">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,5,0,5" Padding="15" BackgroundColor="#F9FFFFFF" Stroke="LightGray">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10" />
                                </Border.StrokeShape>
                                <VerticalStackLayout>
                                    <Label Text="{Binding Name}" FontSize="20" FontAttributes="Bold" TextColor="#2B0B98"/>
                                    <Label Text="{Binding Description}" FontSize="14" TextColor="Gray"/>
                                    <Label Text="{Binding Ingredients, StringFormat='Needs: {0}'}" FontSize="14" TextColor="#FF6B6B" Margin="0,5,0,0"/>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <Button Grid.Row="1" Text="🏠 Back to Home" FontSize="18" FontAttributes="Bold" BackgroundColor="#2B0B98" TextColor="White" CornerRadius="0" HeightRequest="60" Clicked="OnHomeClicked"/>
    </Grid>
</ContentPage>