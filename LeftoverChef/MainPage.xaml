<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeftoverChef.MainPage"
             BackgroundImageSource="bg.jpg"
             Shell.NavBarIsVisible="False" NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="*, Auto">
        <ScrollView Grid.Row="0" Padding="25">
            <VerticalStackLayout Spacing="18" VerticalOptions="Center">

                <Image Source="logo.jpg" HeightRequest="130" HorizontalOptions="Center" Margin="0,0,0,10"/>

                <Label Text="LeftoverChef" FontSize="36" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#2C3E50"/>
                <Label Text="Turn your leftovers into a feast!" FontSize="16" HorizontalOptions="Center" TextColor="#7F8C8D" Margin="0,0,0,20"/>

                <Border StrokeShape="RoundRectangle 15" BackgroundColor="#E3F2FD" Padding="15">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFridgeClicked"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="15">
                        <Label Text="❄️" FontSize="35" VerticalOptions="Center"/>
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="My Fridge" FontSize="20" FontAttributes="Bold" TextColor="#1565C0"/>
                            <Label Text="Check your ingredients" FontSize="13" TextColor="#555555"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 15" BackgroundColor="#FFF3E0" Padding="15">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnStorageClicked"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="15">
                        <Label Text="📖" FontSize="35" VerticalOptions="Center"/>
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="Recipe Storage" FontSize="20" FontAttributes="Bold" TextColor="#E65100"/>
                            <Label Text="Browse Chinese &amp; Western dishes" FontSize="13" TextColor="#555555"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 15" BackgroundColor="#F3E5F5" Padding="15">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSearchClicked"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="15">
                        <Label Text="🔍" FontSize="35" VerticalOptions="Center"/>
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="Search Recipes" FontSize="20" FontAttributes="Bold" TextColor="#7B1FA2"/>
                            <Label Text="Find what to cook" FontSize="13" TextColor="#555555"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 15" BackgroundColor="#E8F5E9" Padding="15">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCreateClicked"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="15">
                        <Label Text="✍️" FontSize="35" VerticalOptions="Center"/>
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="Create Recipe" FontSize="20" FontAttributes="Bold" TextColor="#2E7D32"/>
                            <Label Text="Draft your new dish" FontSize="13" TextColor="#555555"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
        <Button Grid.Row="1" Text="Exit Application" Clicked="OnExitClicked" BackgroundColor="#333333" HeightRequest="60" CornerRadius="0"/>
    </Grid>
</ContentPage>