<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeftoverChef.StoragePage"
             BackgroundImageSource="storage_bg.jpg"
             Shell.NavBarIsVisible="False" NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="*, Auto">
        <Grid Grid.Row="0">
            <ScrollView x:Name="CategoryView" IsVisible="True">
                <VerticalStackLayout Padding="25" Spacing="25" VerticalOptions="Center">
                    <Label Text="Recipe Library" FontSize="30" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#5D4037"/>

                    <Border Stroke="#80FFFFFF" StrokeThickness="1.5" StrokeShape="RoundRectangle 15" Padding="25">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#D9FFFFFF" Offset="0.0" />
                                <GradientStop Color="#66FFF8E1" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.1" Offset="0,5" Radius="10" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="Chinese"/>
                        </Border.GestureRecognizers>
                        <Label Text="🥢 Chinese Food" FontSize="24" HorizontalOptions="Center" TextColor="#E65100"/>
                    </Border>

                    <Border Stroke="#80FFFFFF" StrokeThickness="1.5" StrokeShape="RoundRectangle 15" Padding="25">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#D9FFFFFF" Offset="0.0" />
                                <GradientStop Color="#66FFF8E1" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.1" Offset="0,5" Radius="10" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="Western"/>
                        </Border.GestureRecognizers>
                        <Label Text="🥩 Western Food" FontSize="24" HorizontalOptions="Center" TextColor="#283593"/>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>

            <Grid x:Name="RecipeListGrid" IsVisible="False" RowDefinitions="Auto, *">
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto, Auto" Padding="15" BackgroundColor="#CCEEEEEE">
                    <Label Grid.Column="0" x:Name="ListTitleLabel" FontAttributes="Bold" FontSize="18" VerticalOptions="Center" TextColor="Black"/>
                    <Button Grid.Column="1" Text="🗑️ Clear All" Clicked="OnDeleteAllClicked" FontSize="11" Margin="5,0"/>
                    <Button Grid.Column="2" Text="↩️ Undo" Clicked="OnUndoClicked" FontSize="11"/>
                </Grid>
                <ScrollView Grid.Row="1" Padding="15">
                    <VerticalStackLayout x:Name="RecipeListContainer" Spacing="12"/>
                </ScrollView>
            </Grid>

            <ScrollView x:Name="DetailView" IsVisible="False" Padding="25" BackgroundColor="Transparent">
                <Border Stroke="#99FFFFFF" StrokeThickness="1.5" StrokeShape="RoundRectangle 15" Padding="25">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#D9FFFFFF" Offset="0.0" />
                            <GradientStop Color="#80FFFFFF" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.15" Offset="0,8" Radius="15" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="20">
                        <Label x:Name="DetailName" FontSize="32" FontAttributes="Bold" TextColor="#E65100" HorizontalOptions="Center"/>
                        <Label x:Name="DetailTime" FontSize="18" TextColor="#555555" HorizontalOptions="Center"/>
                        <BoxView HeightRequest="1" Color="#4D000000"/>
                        <Label Text="Ingredients:" FontAttributes="Bold" FontSize="18" TextColor="Black"/>
                        <Label x:Name="DetailIngredients" FontSize="16" TextColor="#333333"/>
                        <Label Text="Instructions:" FontAttributes="Bold" FontSize="18" TextColor="Black"/>
                        <Label x:Name="DetailInstructions" FontSize="16" TextColor="#333333"/>
                        <Label Text="Story:" FontAttributes="Bold" FontSize="18" TextColor="Black"/>
                        <Label x:Name="DetailDescription" FontSize="16" FontAttributes="Italic" TextColor="#555555"/>
                    </VerticalStackLayout>
                </Border>
            </ScrollView>
        </Grid>
        <Button Grid.Row="1" x:Name="DynamicBottomButton" Text="🏠 Home" Clicked="OnDynamicBottomClicked" BackgroundColor="#2A009F" HeightRequest="60" CornerRadius="0"/>
    </Grid>
</ContentPage>